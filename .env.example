# Port the Express/Socket.IO server listens on
PORT=8001

# MongoDB connection string (get this from MongoDB Atlas → Connect → Drivers)
MONGODB_URI=

# Secret used to sign JWTs (use a long random string)
JWT_SECRET=

# Gmail credentials used by server/utils/sendEmail.js for outgoing email
# EMAIL_PASS should be a Gmail App Password, not your account password
EMAIL_USER=
EMAIL_PASS=

# Base URL of the backend API/Socket.IO server, used by the frontend (Vite).
# Leave unset for local dev (defaults to http://localhost:8001).
# In production, set this to your deployed backend URL (e.g. Render service URL).
VITE_API_URL=
